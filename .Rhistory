gendat <- function(samplesize, k, b0, b1, intsd, slopesd, residsd){
cond<-rep(c(-1,1),each=samplesize*k)
dat<-data.frame(subject=rep(rep(1:samplesize,each=k),2),cond=cond)
u<-data.frame(subject=1:n,u0=round(rnorm(samplesize,0,intsd)),
u1=round(rnorm(samplesize,0,slopesd)))
nrows<-dim(dat)[1]
rt<-rep(NA,nrows)
for(i in 1:nrows){
rt[i] <- b0 + u[dat[i,]$subject,]$u0 +
(b1 + u[dat[i,]$subject,]$u1)*dat[i,]$cond + rnorm(1,0,residsd)
}
dat$rt<-rt
return(dat)
}
