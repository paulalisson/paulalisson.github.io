points(mean(x),0,pch=5,col='blue')
##On traduit ca par une loi a priori sur le parametre
prior<-list(B=list(mu=0,V=0.2^2))
tab<-data.frame(x=x)
bayesmod<-MCMCglmm(x~1,data=tab, prior=prior,verbose=FALSE, thin=1)
library(MCMCglmm)
bayesmod<-MCMCglmm(x~1,data=tab, prior=prior,verbose=FALSE, thin=1)
##Le point de vue bayesien fournit une loi a posteriori sur le parametre: cad une distribution de probabilite
## tenant compte de l'information a priori et des observations
hist(bayesmod$Sol,add=TRUE,freq = FALSE)
points(mean(bayesmod$Sol),0,pch=5,col='green')
####Peut moins bien se comporter que l'estimateur frequentiste lorsque l'information a priori integre 'fortement' une information fausse
plot(function(x){dnorm(x,mean=1,sd=0.2)}, xlim=c(-2,2))
points(cbind(x,rep(0,20)), pch=3, col='red')
points(0,0,pch=5, col='purple')
points(mean(x),0,pch=5,col='blue')
prior<-list(B=list(mu=1,V=0.2^2))
tab<-data.frame(x=x)
bayesmod<-MCMCglmm(x~1,data=tab, prior=prior,verbose=FALSE, thin=1)
hist(bayesmod$Sol,add=TRUE,freq = FALSE)
points(mean(bayesmod$Sol),0,pch=5,col='green')
###On peut relacher le degre de certitude de l'information a priori en jouant sur la variance
plot(function(x){dnorm(x,mean=1,sd=0.5)}, xlim=c(-2,2), ylim=c(0,dnorm(0,0,0.5)))
abline(h=0)
points(cbind(x,rep(0,20)), pch=3, col='red')
points(0,0,pch=5, col='purple')
points(mean(x),0,pch=5,col='blue')
prior<-list(B=list(mu=1,V=0.5^2))
tab<-data.frame(x=x)
bayesmod<-MCMCglmm(x~1,data=tab, prior=prior,verbose=FALSE, thin=1)
hist(bayesmod$Sol,add=TRUE,freq = FALSE)
points(mean(bayesmod$Sol),0,pch=5,col='green')
##En agrandissant de plus en plus l'incertitude a priori..
plot(function(x){dnorm(x,mean=1,sd=2)}, xlim=c(-2,2), ylim=c(0,dnorm(0,0,2)))
abline(h=0)
points(cbind(x,rep(0,20)), pch=3, col='red')
points(0,0,pch=5, col='purple')
points(mean(x),0,pch=5,col='blue')
prior<-list(B=list(mu=1,V=2^2))
tab<-data.frame(x=x)
bayesmod<-MCMCglmm(x~1,data=tab, prior=prior,verbose=FALSE, thin=1)
hist(bayesmod$Sol,add=TRUE,freq = FALSE)
points(mean(bayesmod$Sol),0,pch=5,col='green')
##Dans le cas limite de loi a priori non informative on retrouve l'estimateur frequentiste
plot(function(x){dnorm(x,mean=1,sd=10^4)}, xlim=c(-2,2), ylim=c(0,dnorm(0,0,10^4)))
abline(h=0)
points(cbind(x,rep(0,20)), pch=3, col='red')
points(0,0,pch=5, col='purple')
points(mean(x),0,pch=5,col='blue')
prior<-list(B=list(mu=1,V=10^8))
tab<-data.frame(x=x)
bayesmod<-MCMCglmm(x~1,data=tab, prior=prior,verbose=FALSE, thin=1)
hist(bayesmod$Sol,add=TRUE,freq = FALSE)
points(mean(bayesmod$Sol),0,pch=5,col='green')
##Cas d'une information fausse a priori: pour n petit resultat dramatique
plot(function(x){dnorm(x,mean=1,sd=0.2)}, xlim=c(-2,2))
points(cbind(x,rep(0,20)), pch=3, col='red')
points(0,0,pch=5, col='purple')
points(mean(x),0,pch=5,col='blue')
prior<-list(B=list(mu=1,V=0.2^2))
tab<-data.frame(x=x)
bayesmod<-MCMCglmm(x~1,data=tab, prior=prior,verbose=FALSE, thin=1)
hist(bayesmod$Sol,add=TRUE,freq = FALSE)
points(mean(bayesmod$Sol),0,pch=5,col='green')
##Cas d'une information fausse a priori: pour n grand c'est de moins en moins grave, on retrouve le frequentiste
x<-rnorm(1000,mean=0,sd=3)
plot(function(x){dnorm(x,mean=1,sd=0.2)}, xlim=c(-2,2))
points(cbind(x,rep(0,20)), pch=3, col='red', cex=0.2)
points(0,0,pch=5, col='purple')
points(mean(x),0,pch=5,col='blue')
prior<-list(B=list(mu=1,V=0.2^2))
tab<-data.frame(x=x)
bayesmod<-MCMCglmm(x~1,data=tab, prior=prior,verbose=FALSE, thin=1)
hist(bayesmod$Sol,add=TRUE,freq = FALSE)
points(mean(bayesmod$Sol),0,pch=5,col='green')
###On s'interesse a la prediction du relativiseur pour des 'relative clauses' ayant pour sujet des objets.
###Les donnees sont issues de textes dans plusieurs corpus, individus=phrases avec une relative en gros, pretraitees
### via une AFM pour representer des variables stylistiques et internes sous formes quantitative et d?corr?l?es
objrel<-read.table('GraphMillerObjrelquantitativedescriptorsafterAFM.txt', header = TRUE)
setwd("~/Desktop")
###On s'interesse a la prediction du relativiseur pour des 'relative clauses' ayant pour sujet des objets.
###Les donnees sont issues de textes dans plusieurs corpus, individus=phrases avec une relative en gros, pretraitees
### via une AFM pour representer des variables stylistiques et internes sous formes quantitative et d?corr?l?es
objrel<-read.table('GraphMillerObjrelquantitativedescriptorsafterAFM.txt', header = TRUE)
objrel$rel <- relevel(objrel$rel, ref = "THAT") ##Choix d'un relativizer de reference, obligatoire pour un GLM
objrel2<-objrel[objrel$RC.length>=2,]
objrel2$rel <- relevel(objrel2$rel, ref = "THAT") # the data where RCLn >= 2
objrel2$time2<-as.factor(objrel2$time2)
View(objrel2)
#%%%%%%%%%%%%%%%%% Si vous n'avez pas la patience
load('modelebayesien.Rdata')
autocorr(obj.m1a$Sol[,1:40])
c <- length(levels(objrel$category))
# this is the matrix of values of the fixed effects
modMat2 <- as.data.frame(as.matrix(obj.m1a$X))
dim(modMat2)
N <- nrow(modMat2)/2 # number of observations
# the matrix for which
modWhich <- modMat2[1:N,] # the fixed effects
# random effects
modWhich$category <- 0 # category
modWhich$catXcorpus <- 0 # cat * corpus
modWhich$file <- 0 # file
# the matrix for zero
modZero <- modMat2[(N+1):(2*N),]
modZero$category <- 0
modZero$catXcorpus <- 0
modZero$file <- 0
# get the posterior means across the draws for the fixed effects and each
# level of the random effects. The posterior estimates are stored in fit$Sol
means2 <- apply(obj.m1a$Sol, 2, mean)
# fixed effects
coefs3 <- means2[1:40]
# random effects
categoryIntsWhich <- means2[41:55]
categoryIntsZero <- means2[56:70]
categorySlopes <- means2[71:130]
filesWhich <- means2[131:1706]
filesZero <- means2[1707:3282]
# Now loop through each observation and multiply its features by the model
# formula and random group level adjustments
for (i in 1:N){
# do which
modWhich[i, 1:40] <- as.vector(modWhich[i, 1:40] * coefs3)
ranef1w <- paste("traitrel.WHICH.category",
objrel2[i, 6], sep = '.')
modWhich[i, 41] <- as.vector(categoryIntsWhich[ranef1w])
ranef2 <- paste(paste("corpus", objrel2[i, 2], sep=""), paste("category",
objrel2[i, 6],sep='.'), sep = '.')
modWhich[i, 42] <- as.vector(categorySlopes[ranef2])
ranef3w <- paste("traitrel.WHICH.file",
objrel2[i, 5], sep = '.')
modWhich[i, 43] <- as.vector(filesWhich[ranef3w])
# do zero
modZero[i, 1:40] <- as.vector(modZero[i, 1:40] * coefs3)
ranef1z <- paste("traitrel.ZERO.category",
objrel2[i, 6], sep = '.')
modZero[i, 41] <- as.vector(categoryIntsZero[ranef1z])
ranef2 <- paste(paste("corpus", objrel2[i, 2], sep=""), paste("category",
objrel2[i, 6],sep='.'), sep = '.')
modZero[i, 42] <- as.vector(categorySlopes[ranef2])
ranef3z <- paste("traitrel.ZERO.file",
objrel2[i, 5], sep = '.')
modZero[i, 43] <- as.vector(filesZero[ranef3z])
}
head(modWhich)
sW <- rowSums(modWhich)
sZ <- rowSums(modZero)
sum(sW<=0&sZ<=0)
pred.Z <- ifelse(sZ > 0, "ZERO", "THAT")
# get the predicted outcome for each observation
pred.W <- ifelse(sW > 0, "WHICH", "THAT")
pred.rel <- vector('character',N)
max.prob <- vector('numeric',N)
for (i in 1:N){
a <- sW[i]
b <- sZ[i]
# calculate predictions
# I got this from post by Jarrod Hadfield:
# https://stat.ethz.ch/pipermail/r-sig-mixed-models/2014q3/022422.html
P.that <- 1/(1 + exp(a) + exp(b))
P.which <- exp(a)/(1+exp(a) + exp(b))
P.zero <- exp(b)/(1 + exp(a) + exp(b))
max.prob[i] <- max(P.that, P.zero, P.which)
#cat(i, a, b)
#print(max(P.that, P.zero, P.which))
# determine which relativizer has the highest probability
if (max(P.that, P.zero, P.which) == P.that){
pred.rel[i] <-  "THAT"
}
else if (max(P.that, P.zero, P.which) == P.zero){
pred.rel[i] <- "ZERO"
}
else if (max(P.that, P.zero, P.which) == P.which){
pred.rel[i] <- "WHICH"
}
else pred.rel[i] <- "NA"
}
objrel2$predicted <- factor(pred.rel)
objrel2$observed <- objrel2$rel
objrel2$max.prob <- max.prob
# table of predictions vs observations
addmargins(xtabs(~ observed + predicted, objrel2))
# predictive accuracy
sum(objrel2$predicted == objrel2$observed)/N
