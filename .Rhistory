library(MASS)
## number of subjects:
n<-100
## std dev of the intercept adjustments by subjects
intsd<-100
## std dev of the slope adjustments by subjects
slopesd<-50
## the covariance between the intercept and slope adjustments covariance<-intsd*slopesd*rho
## the variance-covariance matrix: Sigma<-matrix(c(intsd^2,covariance,
covariance<-intsd*slopesd*rho
Sigma<-matrix(c(intsd^2,covariance,
covariance,slopesd^2), byrow=FALSE,ncol=2)
u<-mvrnorm(n,mu=c(0,0),Sigma=Sigma)
u
# ex 2
gendat <- function(samplesize, k, b0, b1, intsd, slopesd, residsd,rho){
cond<-rep(c(-1,1),each=samplesize*k)
dat<-data.frame(subject=rep(rep(1:samplesize,each=k),2),cond=cond)
covariance<-intsd*slopesd*rho
Sigma<-matrix(c(intsd^2,covariance,
covariance,slopesd^2), byrow=FALSE,ncol=2)
u<-data.frame(subject=1:samplesize,mvrnorm(samplesize,mu=c(0,0),Sigma=Sigma))
nrows<-dim(dat)[1]
rt<-rep(NA,nrows)
for(i in 1:nrows){
rt[i] <- b0 + u[dat[i,]$subject,]$u0 +
(b1 + u[dat[i,]$subject,]$u1)*dat[i,]$cond + rnorm(1,0,residsd)
}
dat$rt<-rt
return(dat)
}
# ex 2
gendat <- function(samplesize, k, b0, b1, intsd, slopesd, residsd,rho){
cond<-rep(c(-1,1),each=samplesize*k)
dat<-data.frame(subject=rep(rep(1:samplesize,each=k),2),cond=cond)
covariance<-intsd*slopesd*rho
Sigma<-matrix(c(intsd^2,covariance,
covariance,slopesd^2), byrow=FALSE,ncol=2)
u <- mvrnorm(samplesize,mu=c(0,0),Sigma=Sigma)
u<-data.frame(subject=1:samplesize, u0=u[,1], u1=u[,2])
nrows<-dim(dat)[1]
rt<-rep(NA,nrows)
for(i in 1:nrows){
rt[i] <- b0 + u[dat[i,]$subject,]$u0 +
(b1 + u[dat[i,]$subject,]$u1)*dat[i,]$cond + rnorm(1,0,residsd)
}
dat$rt<-rt
return(dat)
}
dat<-gendat(samplesize=20,k=20,b0=725,b1=30,intsd=100,slopesd=50,residsd=200,rho=0.2)
dat
m2<-lmer(rt~cond+(1+cond|subject),dat)
summary(m2)
