##########Bonne maniere de predire a partir d'un modele mixte: marginalisation######################################
####Le moins couteux: dans l'espace 'logit', prendre pour effet aleatoire la moyenne. Fonctions directement implementee
obj.m1a$Random$formula
##On marginalise, cad, prend un effet aleatoire moyen (comme on ferait si on avait un nouveau file), pour la prediction
pred.terms3<-predict.MCMCglmm(obj.m1a, marginal = obj.m1a$Random$formula, type='terms', posterior = 'mean')
sW3<-pred.terms3[1:5287]
sZ3<-pred.terms3[5288:10574]
sum(sW3<=0&sZ3<=0)
pred.rel3 <- vector('character',N)
max.prob3 <- vector('numeric',N)
for (i in 1:N){
a <- sW3[i]
b <- sZ3[i]
# calculate predictions
P.that <- 1/(1 + exp(a) + exp(b))
P.which <- exp(a)/(1+exp(a) + exp(b))
P.zero <- exp(b)/(1 + exp(a) + exp(b))
max.prob3[i] <- max(P.that, P.zero, P.which)
#cat(i, a, b)
#print(max(P.that, P.zero, P.which))
# determine which relativizer has the highest probability
if (max(P.that, P.zero, P.which) == P.that){
pred.rel3[i] <-  "THAT"
}
else if (max(P.that, P.zero, P.which) == P.zero){
pred.rel3[i] <- "ZERO"
}
else if (max(P.that, P.zero, P.which) == P.which){
pred.rel3[i] <- "WHICH"
}
else pred.rel3[i] <- "NA"
}
table(objrel2$rel,pred.rel3)
sum(objrel2$rel==pred.rel3)/N
